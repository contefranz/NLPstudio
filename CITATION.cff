    orcid: "https://orcid.org/0000-0002-5130-7745"
    affiliation: "Bocconi University"
version: 1.0.1
date-released: "2026-06-05"
license: GPL-3.0-or-later
repository-code: "https://github.com/contefranz/NLPstudio"
url: "https://contefranz.github.io/NLPstudio/"
keywords:
  - text-analysis
  - topic-modeling
  - natural-language-processing
  - corpus
  - quanteda
  - r
